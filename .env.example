# ─────────────────────────────────────────────────────────────────────────────
# ComplianceGxP — environment configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────
# Anthropic API key (get one at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Admin key — used to manage clients and API keys via CLI / API
ADMIN_API_KEY=change-me-to-a-random-secret

# ── Optional ─────────────────────────────────────────────────────────────────
# OpenAI embeddings (leave blank to use the built-in local sentence-transformers)
# OPENAI_API_KEY=sk-...

# Model to use for completions (default: claude-sonnet-4-5-20251001)
# ANTHROPIC_MODEL=claude-sonnet-4-5-20251001

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO

# Port the API listens on inside the container (default: 8000)
# PORT=8000
